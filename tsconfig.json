{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node", "@playwright/test"],
        "allowJs": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": false,
        "skipLibCheck": true
    }, 

    "exclude": [
        "node_modules",
        "playwright-report",
        "test-results"
    ]
}
